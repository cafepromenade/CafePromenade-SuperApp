<Window
    x:Class="CafePromenade.Desktop.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:CafePromenade.Desktop.Views">
    <NavigationView x:Name="NavView" IsBackButtonVisible="Collapsed" SelectionChanged="NavView_SelectionChanged" PaneDisplayMode="Top">
        <NavigationView.MenuItems>
            <NavigationViewItem Content="Dashboard" Tag="Dashboard" Icon="Home" />
            <NavigationViewItem Content="Repositories" Tag="Repositories" Icon="Library" />
            <NavigationViewItem Content="VeraCrypt" Tag="VeraCrypt" Icon="Lock" />
            <NavigationViewItem Content="NTLite" Tag="NTLite" Icon="Repair" />
            <NavigationViewItem Content="Messaging" Tag="Messaging" Icon="Message" />
            <NavigationViewItem Content="PowerToys" Tag="PowerToys" Icon="KeyboardShortcut" />
            <NavigationViewItem Content="Docker" Tag="Docker" Icon="AllApps" />
            <NavigationViewItem Content="3D Printing" Tag="ThreeDPrint" Icon="Print3D" />
            <NavigationViewItem Content="Minecraft" Tag="Minecraft" Icon="World" />
            <NavigationViewItem Content="Downloads" Tag="Downloads" Icon="Download" />
            <NavigationViewItem Content="System Tools" Tag="SystemTools" Icon="DeveloperTools" />
            <NavigationViewItem Content="Automation" Tag="Automation" Icon="Clock" />
        </NavigationView.MenuItems>
        <NavigationView.FooterMenuItems>
            <NavigationViewItem Content="About" Tag="About" Icon="Info" />
        </NavigationView.FooterMenuItems>
        <Frame x:Name="ContentFrame" />
    </NavigationView>
</Window>
